#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
    echo "Usage: scripts/build-combined-image <version> [image-tag]" >&2
    exit 1
fi

version="$1"
image="${2:-gs-${version}:combined}"
normal_image="gs-${version}"

if [ ! -f "versions/${version}/Dockerfile" ]; then
    echo "Unknown Ghostscript version: ${version}" >&2
    exit 1
fi

source_url=""
source_dir=""
bootstrap=""
patch_time_h="false"
install_build_deps=""
install_runtime_deps=""
build_jobs="${GS_BUILD_JOBS:-2}"

release_tag="gs${version//./}"

case "$version" in
    8.63)
        source_url="https://github.com/ArtifexSoftware/ghostpdl/archive/refs/tags/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostpdl-ghostscript-${version}/gs"
        bootstrap="autogen"
        patch_time_h="true"
        install_build_deps='apt-get update && apt-get install -y --no-install-recommends autoconf automake build-essential ca-certificates libx11-dev libxext-dev libxt-dev && rm -rf /var/lib/apt/lists/*'
        install_runtime_deps='apt-get update && apt-get install -y --no-install-recommends libx11-6 libxext6 libxt6 && rm -rf /var/lib/apt/lists/*'
        build_jobs="${GS_BUILD_JOBS:-1}"
        ;;
    8.64|8.71|9.01)
        source_url="https://github.com/ArtifexSoftware/ghostpdl/archive/refs/tags/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostpdl-ghostscript-${version}/gs"
        bootstrap="autogen"
        patch_time_h="true"
        install_build_deps='apt-get update && apt-get install -y --no-install-recommends autoconf automake build-essential ca-certificates libx11-dev libxext-dev libxt-dev && rm -rf /var/lib/apt/lists/*'
        install_runtime_deps='apt-get update && apt-get install -y --no-install-recommends libx11-6 libxext6 libxt6 && rm -rf /var/lib/apt/lists/*'
        build_jobs="${GS_BUILD_JOBS:-1}"
        ;;
    9.06)
        source_url="https://github.com/ArtifexSoftware/ghostpdl/archive/refs/tags/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostpdl-ghostscript-${version}/gs"
        bootstrap="autogen"
        patch_time_h="true"
        install_build_deps='apt-get -o Acquire::Check-Valid-Until=false update && apt-get install -y --force-yes --no-install-recommends autoconf automake build-essential ca-certificates libx11-dev libxext-dev libxt-dev && rm -rf /var/lib/apt/lists/*'
        install_runtime_deps='apt-get -o Acquire::Check-Valid-Until=false update && apt-get install -y --force-yes --no-install-recommends libx11-6 libxext6 libxt6 && rm -rf /var/lib/apt/lists/*'
        build_jobs="${GS_BUILD_JOBS:-1}"
        ;;
    9.10|9.14)
        source_url="https://github.com/ArtifexSoftware/ghostpdl/archive/refs/tags/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostpdl-ghostscript-${version}/gs"
        bootstrap="autogen"
        patch_time_h="true"
        install_build_deps='yum install -y autoconf automake ca-certificates gcc gcc-c++ libX11-devel libXext-devel libXt-devel make tar gzip && yum clean all'
        install_runtime_deps='yum install -y libX11 libXext libXt && yum clean all'
        build_jobs="${GS_BUILD_JOBS:-1}"
        ;;
    9.18|9.22)
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        install_build_deps='apt-get update && apt-get install -y --no-install-recommends build-essential ca-certificates libx11-dev libxext-dev libxt-dev && rm -rf /var/lib/apt/lists/*'
        install_runtime_deps='apt-get update && apt-get install -y --no-install-recommends libx11-6 libxext6 libxt6 && rm -rf /var/lib/apt/lists/*'
        ;;
    9.20|9.26)
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        install_build_deps='dnf install -y --setopt=install_weak_deps=False ca-certificates gcc gcc-c++ libX11-devel libXext-devel libXt-devel make tar gzip && dnf clean all'
        install_runtime_deps='dnf install -y --setopt=install_weak_deps=False libX11 libXext libXt && dnf clean all'
        ;;
    9.50|9.53.3|9.55.0|10.0.0|10.02.1|10.03.0|10.05.0|10.05.1|10.07.1)
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        install_build_deps='apt-get update && apt-get install -y --no-install-recommends build-essential ca-certificates libx11-dev libxext-dev libxt-dev && rm -rf /var/lib/apt/lists/*'
        install_runtime_deps='apt-get update && apt-get install -y --no-install-recommends libx11-6 libxext6 libxt6 && rm -rf /var/lib/apt/lists/*'
        ;;
    9.52)
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        install_build_deps='zypper --non-interactive --no-gpg-checks refresh && zypper --non-interactive --no-gpg-checks install --no-recommends ca-certificates gcc gcc-c++ libX11-devel libXext-devel libXt-devel make tar gzip && zypper clean --all'
        install_runtime_deps='zypper --non-interactive --no-gpg-checks refresh && zypper --non-interactive --no-gpg-checks install --no-recommends libX11-6 libXext6 libXt6 && zypper clean --all'
        ;;
    9.56.1|10.03.1)
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        install_build_deps='dnf install -y --setopt=install_weak_deps=False ca-certificates gcc gcc-c++ libX11-devel libXext-devel libXt-devel make tar gzip && dnf clean all'
        install_runtime_deps='dnf install -y --setopt=install_weak_deps=False libX11 libXext libXt && dnf clean all'
        ;;
    *)
        echo "Unknown Ghostscript version for combined build: $version" >&2
        exit 1
        ;;
esac

if ! docker image inspect "$normal_image" >/dev/null 2>&1; then
    docker build -t "$normal_image" "versions/${version}"
fi

dockerfile="$(mktemp)"
build_context="$(mktemp -d)"
trap 'rm -f "$dockerfile"; rm -rf "$build_context"' EXIT

cat > "$dockerfile" <<EOF
FROM ${normal_image} AS debug-builder

ARG GS_VERSION=${version}

RUN ${install_build_deps}

ADD ${source_url} /tmp/gs.tar.gz

RUN tar xzf /tmp/gs.tar.gz -C /tmp && \\
    cd "${source_dir}" && \\
    if [ "${patch_time_h}" = "true" ]; then find . -name time_.h -exec sed -i '/^struct timeval {$/,/^};$/d' {} +; fi && \\
    if [ "${bootstrap}" = "autogen" ]; then cp /usr/share/automake-*/config.guess /usr/share/automake-*/config.sub . 2>/dev/null || true; fi && \\
    export CFLAGS="-g3 -O0 -fno-omit-frame-pointer" && \\
    export CXXFLAGS="-g3 -O0 -fno-omit-frame-pointer" && \\
    if [ "${bootstrap}" = "autogen" ]; then ./autogen.sh --prefix=/opt/gs-debug; else ./configure --prefix=/opt/gs-debug; fi && \\
    make -j${build_jobs} && \\
    make install && \\
    rm -rf /tmp/gs.tar.gz /tmp/ghostpdl-ghostscript-${version} /tmp/ghostscript-${version}

FROM ${normal_image}

COPY --from=debug-builder /opt/gs-debug /opt/gs-debug

RUN ${install_runtime_deps} && \\
    ln -sf /opt/gs-debug/bin/gs /usr/local/bin/gs-debug

ENV PATH="/usr/local/bin:\${PATH}"

LABEL org.opencontainers.image.architecture="amd64" \\
      net.w0ot.ghostscript.cpu-architecture="x86_64" \\
      net.w0ot.ghostscript.build-flavor="combined" \\
      net.w0ot.ghostscript.debug-symbols="true"

WORKDIR /work
ENTRYPOINT ["gs"]
EOF

docker build -f "$dockerfile" -t "$image" "$build_context"
