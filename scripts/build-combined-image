#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
    echo "Usage: scripts/build-combined-image <version> [image-tag]" >&2
    exit 1
fi

version="$1"
image="${2:-gs-${version}:combined}"
normal_image="gs-${version}"
debug_image="gs-${version}:debug"

if [ ! -f "versions/${version}/Dockerfile" ]; then
    echo "Unknown Ghostscript version: ${version}" >&2
    exit 1
fi

if ! docker image inspect "$normal_image" >/dev/null 2>&1; then
    docker build -t "$normal_image" "versions/${version}"
fi

if ! docker image inspect "$debug_image" >/dev/null 2>&1; then
    scripts/build-debug-image "$version" "$debug_image"
fi

dockerfile="$(mktemp)"
build_context="$(mktemp -d)"
trap 'rm -f "$dockerfile"; rm -rf "$build_context"' EXIT

cat > "$dockerfile" <<EOF
FROM ${normal_image} AS normal-image

RUN set -eux; \\
    mkdir -p /normal-root/root /normal-root/meta; \\
    clone_into() { dst="/normal-root/root\$(dirname "\$1")"; mkdir -p "\$dst"; cp "\$2" "\$1" "\$dst/"; }; \\
    gs_path="\$(readlink -f "\$(command -v gs)")"; \\
    printf '%s\n' "\$gs_path" > /normal-root/meta/gs.path; \\
    clone_into "\$gs_path" -a; \\
    ldd "\$gs_path" | awk '/=> \// { print \$3 } /^\// { print \$1 }' | \\
        grep -Ev '/(ld-linux|libBrokenLocale|libSegFault|libanl|libc|libcidn|libcrypt|libdl|libm|libmvec|libnsl|libnss_|libpthread|libresolv|librt|libthread_db|libutil)\\.so' | \\
        sort -u | \\
        while IFS= read -r lib; do clone_into "\$lib" -L; done; \\
    for path in \\
        /opt/gs \\
        /usr/lib/ghostscript \\
        /usr/lib64/ghostscript \\
        /usr/lib/x86_64-linux-gnu/ghostscript \\
        /usr/share/color \\
        /usr/share/fonts \\
        /usr/share/ghostscript \\
        /usr/share/gs-gpl \\
        /usr/share/icc; do \\
        if [ -e "\$path" ]; then clone_into "\$path" -a; fi; \\
    done

FROM ${debug_image}

# Move the source-built debug tree aside, but keep /opt/gs pointing at it so the
# gs-debug binary's compiled-in resource search path (/opt/gs/share/ghostscript)
# still resolves and gs-debug can render, not just report --version.
RUN mv /opt/gs /opt/gs-debug && ln -s /opt/gs-debug /opt/gs

COPY --from=normal-image /normal-root/root/. /opt/gs-normal/root/
COPY --from=normal-image /normal-root/meta/. /opt/gs-normal/meta/

RUN set -eux; \\
    for path in \\
        /usr/share/color \\
        /usr/share/fonts \\
        /usr/share/ghostscript \\
        /usr/share/gs-gpl \\
        /usr/share/icc; do \\
        if [ -e "/opt/gs-normal/root\$path" ] && [ ! -e "\$path" ]; then \\
            mkdir -p "\$(dirname "\$path")"; \\
            ln -s "/opt/gs-normal/root\$path" "\$path"; \\
        fi; \\
    done; \\
    { \\
        printf '%s\n' '#!/bin/sh'; \\
        printf '%s\n' 'set -eu'; \\
        printf '%s\n' 'normal_root=/opt/gs-normal/root'; \\
        printf '%s\n' 'gs_path="\$(cat /opt/gs-normal/meta/gs.path)"'; \\
        printf '%s\n' 'normal_lib_path="\$normal_root/lib/x86_64-linux-gnu:\$normal_root/usr/lib/x86_64-linux-gnu:\$normal_root/lib64:\$normal_root/usr/lib64:\$normal_root/lib:\$normal_root/usr/lib"'; \\
        printf '%s\n' 'if [ "\${LD_LIBRARY_PATH:-}" ]; then'; \\
        printf '%s\n' '    export LD_LIBRARY_PATH="\$normal_lib_path:\$LD_LIBRARY_PATH"'; \\
        printf '%s\n' 'else'; \\
        printf '%s\n' '    export LD_LIBRARY_PATH="\$normal_lib_path"'; \\
        printf '%s\n' 'fi'; \\
        printf '%s\n' 'exec "\$normal_root\$gs_path" "\$@"'; \\
    } > /usr/local/bin/gs; \\
    chmod +x /usr/local/bin/gs; \\
    ln -sf /opt/gs-debug/bin/gs /usr/local/bin/gs-debug

ENV PATH="/usr/local/bin:/opt/gs-debug/bin:\${PATH}"

LABEL org.opencontainers.image.architecture="amd64" \\
      net.w0ot.ghostscript.cpu-architecture="x86_64" \\
      net.w0ot.ghostscript.build-flavor="combined" \\
      net.w0ot.ghostscript.debug-symbols="true"

WORKDIR /work
ENTRYPOINT ["gs"]
EOF

docker build --no-cache -f "$dockerfile" -t "$image" "$build_context"
