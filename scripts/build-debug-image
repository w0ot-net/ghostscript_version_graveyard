#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
    echo "Usage: scripts/build-debug-image <version> [image-tag]" >&2
    exit 1
fi

version="$1"
image="${2:-gs-${version}:debug}"

# Alternate-distro builds use a <version>-<distro> directory name (e.g.
# 9.54.0-centos9). The upstream Ghostscript version (used for source tarballs and
# release tags) is the part before the first dash.
base_version="${version%%-*}"

# Debug build method, in order of preference (distro debug symbols first, source
# only as a fallback):
#   deb        - Debian/Ubuntu: install the distro debug symbols (ghostscript-dbg
#                or *-dbgsym), recombine into the gs/libgs binaries with eu-unstrip.
#   rpm-pm     - Fedora/openSUSE: fetch the version-matched ghostscript-debuginfo
#                (and debugsource) from the archive and recombine.
#   debuginfo  - CentOS-hosted RPM payloads (7.07/8.60/8.62) whose normal image is
#                an extracted RPM (no rpmdb), so a fixed debuginfo URL is used.
#   source     - compile from an upstream/orig tarball with -g3 -O0. Used for the
#                pure-source versions and where no distro gs debug package exists.
# Every method leaves the Ghostscript source under /usr/src/ghostscript.
method="source"

# source method inputs
source_url=""
source_dir=""
bootstrap=""
base_image=""
patch_time_h="false"
build_jobs="${GS_BUILD_JOBS:-2}"
extra_apt=""

# debuginfo (fixed-URL) method inputs
debuginfo_url=""
libgs_version=""

# deb method inputs
deb_dbg_pkgs=""    # debug-symbol packages to install
deb_dbg_repo=""    # optional extra apt source lines (e.g. ddebs), newline-separated
deb_update_opts="" # extra apt-get update options (e.g. expired-archive override)
deb_install_opts="" # extra apt-get install options (e.g. --force-yes)
src_url=""         # source tarball to unpack into /usr/src/ghostscript

# rpm-pm method inputs
dbg_bases=""      # space-separated archive dirs to search for the debuginfo rpms

release_tag="gs${base_version//./}"

case "$version" in
    8.63|8.64|8.71|9.01|9.06|9.10|9.14|9.15|9.16)
        # Source fallbacks: 9.06 (jessie ghostscript-dbg uses a path-style layout
        # eu-unstrip rejects), 9.10/9.14/9.16 (Fedora 20/21/22 archive cannot
        # install elfutils to run the recombine), and 9.15 (the vivid normal image
        # is an unpacked deb on a newer base, with no usable dbg package).
        base_image="ubuntu:18.04"
        source_url="https://github.com/ArtifexSoftware/ghostpdl/archive/refs/tags/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostpdl-ghostscript-${version}/gs"
        bootstrap="autogen"
        patch_time_h="true"
        build_jobs="1"
        ;;
    9.53.3|9.55.0|10.0.0|10.02.1|10.03.0|10.05.0|10.05.1|10.07.1)
        # Pure-source versions and the Debian/Ubuntu versions whose distro ships
        # no usable gs debug package: bullseye/bookworm/trixie and plucky have no
        # gs dbgsym at all; jammy/noble (9.55.0/10.02.1) ship a dbgsym only for
        # the GA revision, not the installed -security point release. Build from
        # the upstream release tarball.
        base_image="ubuntu:24.04"
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        ;;
    8.01|8.15|8.50)
        # GNU/GPL Ghostscript built from the distro orig tarball (the ghostpdl
        # GitHub tags report the wrong version for these).
        base_image="ubuntu:18.04"
        source_url="http://old-releases.ubuntu.com/ubuntu/pool/main/g/gs-gpl/gs-gpl_${version}.orig.tar.gz"
        source_dir="AUTO"
        bootstrap="configure"
        patch_time_h="true"
        build_jobs="1"
        extra_apt="libjpeg-dev libpng-dev zlib1g-dev libtiff-dev"
        ;;
    8.54)
        base_image="ubuntu:18.04"
        source_url="http://archive.debian.org/debian/pool/main/g/gs-gpl/gs-gpl_8.54.dfsg.1.orig.tar.gz"
        source_dir="AUTO"
        bootstrap="configure"
        patch_time_h="true"
        build_jobs="1"
        extra_apt="libjpeg-dev libpng-dev zlib1g-dev libtiff-dev"
        ;;
    8.61)
        base_image="ubuntu:18.04"
        source_url="https://github.com/ArtifexSoftware/ghostpdl/archive/refs/tags/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostpdl-ghostscript-${version}/gs"
        bootstrap="autogen"
        patch_time_h="true"
        build_jobs="1"
        extra_apt="libjpeg-dev libpng-dev zlib1g-dev libtiff-dev"
        ;;
    9.20)
        # Fedora 25 archive cannot install elfutils (elfutils-libelf conflict),
        # so the recombine is not possible; build from source instead.
        base_image="ubuntu:18.04"
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        ;;
    9.19|9.21)
        # Ubuntu zesty/artful (EOL): ghostscript-dbg in main, elfutils in
        # universe, both from old-releases.ubuntu.com (expired Valid-Until).
        method="deb"
        deb_update_opts="-o Acquire::Check-Valid-Until=false"
        deb_dbg_pkgs="ghostscript-dbg"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.53.0|9.53.2)
        # Debian unstable snapshot (snapshot.debian.org sources are baked into the
        # normal image); the matching ghostscript-dbg lives in the same snapshot.
        method="deb"
        deb_dbg_pkgs="ghostscript-dbg"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${base_version}.tar.gz"
        ;;
    9.56.0)
        # Debian unstable snapshot; by 2022 the symbols are an automatic -dbgsym
        # in the separate debian-debug archive (sid-debug suite).
        method="deb"
        deb_dbg_repo="deb [check-valid-until=no] http://snapshot.debian.org/archive/debian-debug/20220330T151636Z/ sid-debug main"
        deb_dbg_pkgs="ghostscript-dbgsym"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${base_version}.tar.gz"
        ;;
    9.18)
        # Ubuntu xenial: ghostscript-dbg in main; elfutils lives in universe.
        method="deb"
        deb_dbg_repo="deb http://archive.ubuntu.com/ubuntu xenial universe"
        deb_dbg_pkgs="ghostscript-dbg"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.22|9.50)
        # Ubuntu bionic/focal: manual ghostscript-dbg package in main.
        method="deb"
        deb_dbg_pkgs="ghostscript-dbg"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.27)
        # Debian buster: ghostscript-dbg from archive.debian.org (buster is EOL,
        # so override the expired Valid-Until check). Buster is the last Debian
        # release with a real ghostscript-dbg package.
        method="deb"
        deb_update_opts="-o Acquire::Check-Valid-Until=false"
        deb_dbg_pkgs="ghostscript-dbg"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.26)
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/30/Everything/x86_64/debug/tree/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.25)
        # Fedora 29 GA ghostscript-debuginfo (updates pocket is disabled to keep 9.25).
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/29/Everything/x86_64/debug/tree/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.53.1)
        # Fedora 33 GA ghostscript-debuginfo (updates pocket is disabled to keep 9.53.1).
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/33/Everything/x86_64/debug/tree/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.54.0)
        # Fedora 35 GA ghostscript-debuginfo.
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/35/Everything/x86_64/debug/tree/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    10.01.2)
        # Fedora 39 GA ghostscript-debuginfo (updates pocket is disabled to keep 10.01.2).
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/39/Everything/x86_64/debug/tree/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    10.01.0)
        # Fedora 38 GA ghostscript-debuginfo (updates pocket is disabled to keep 10.01.0).
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/38/Everything/x86_64/debug/tree/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${base_version}.tar.gz"
        ;;
    9.56.1)
        # Installed version comes from fedora 36 updates, so search updates first.
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/updates/36/Everything/x86_64/debug/Packages/g https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/36/Everything/x86_64/debug/tree/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    10.03.1)
        method="rpm-pm"
        dbg_bases="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/41/Everything/x86_64/debug/tree/Packages/g https://archives.fedoraproject.org/pub/archive/fedora/linux/updates/41/Everything/x86_64/debug/Packages/g"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.52)
        method="rpm-pm"
        dbg_bases="http://download.opensuse.org/debug/distribution/leap/15.5/repo/oss/x86_64"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    9.23)
        # openSUSE Leap 15.0 GA ghostscript-debuginfo from the hosted debug repo.
        method="rpm-pm"
        dbg_bases="http://download.opensuse.org/debug/distribution/leap/15.0/repo/oss/x86_64"
        src_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        ;;
    7.07|8.60|8.62)
        # CentOS-hosted extracted-RPM payloads (no rpmdb): fixed debuginfo URL.
        method="debuginfo"
        libgs_version="$version"
        case "$version" in
            7.07) debuginfo_url="http://debuginfo.centos.org/4/x86_64/ghostscript-debuginfo-7.07-33.2.el4_6.1.x86_64.rpm" ;;
            8.60) debuginfo_url="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/8/Everything/x86_64/debug/ghostscript-debuginfo-8.60-5.fc8.x86_64.rpm" ;;
            8.62) debuginfo_url="https://archives.fedoraproject.org/pub/archive/fedora/linux/releases/9/Everything/x86_64/debug/ghostscript-debuginfo-8.62-3.fc9.x86_64.rpm" ;;
        esac
        ;;
    9.51|10.04.0|10.06.0)
        # Arch Linux pinned-snapshot versions. Arch ships no downloadable debug
        # packages; symbols are only served by debuginfod. The arch method probes
        # debuginfod.archlinux.org for the gs build-id and recombines if present,
        # otherwise it falls back to the source build configured below.
        method="arch"
        base_image="ubuntu:24.04"
        source_url="https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/${release_tag}/ghostscript-${version}.tar.gz"
        source_dir="/tmp/ghostscript-${version}"
        bootstrap="configure"
        src_url="$source_url"
        ;;
    *)
        echo "Unknown Ghostscript version for debug build: $version" >&2
        exit 1
        ;;
esac

dockerfile="$(mktemp)"
build_context="$(mktemp -d)"
trap 'rm -f "$dockerfile"; rm -rf "$build_context"' EXIT

# Shared label block appended to every generated Dockerfile.
labels='LABEL org.opencontainers.image.architecture="amd64" \
      net.w0ot.ghostscript.cpu-architecture="x86_64" \
      net.w0ot.ghostscript.build-flavor="debug" \
      net.w0ot.ghostscript.debug-symbols="true"'

ensure_normal_image() {
    normal_image="gs-${version}"
    if ! docker image inspect "$normal_image" >/dev/null 2>&1; then
        docker build -t "$normal_image" "versions/${version}"
    fi
}

if [ "$method" = "debuginfo" ]; then
    ensure_normal_image
    cat > "$dockerfile" <<EOF
FROM gs-${version}

# Recombine the stripped distro gs (and libgs) with the detached debug symbols
# from ghostscript-debuginfo so the gs executable itself carries .debug_info,
# and keep the matching source under /usr/src/ghostscript.
RUN set -eux; \\
    yum -y install elfutils && yum clean all; \\
    curl -fsSL -o /tmp/dbg.rpm "${debuginfo_url}"; \\
    mkdir -p /tmp/dbg; cd /tmp/dbg; rpm2cpio /tmp/dbg.rpm | cpio -idm --quiet; \\
    mkdir -p /opt/gs/bin; \\
    eu-unstrip /usr/bin/gs /tmp/dbg/usr/lib/debug/usr/bin/gs.debug -o /opt/gs/bin/gs; \\
    chmod +x /opt/gs/bin/gs; \\
    eu-unstrip /usr/lib64/libgs.so.${libgs_version} \\
        /tmp/dbg/usr/lib/debug/usr/lib64/libgs.so.${libgs_version}.debug \\
        -o /tmp/libgs.unstripped; \\
    cp /tmp/libgs.unstripped /usr/lib64/libgs.so.${libgs_version}; \\
    ldconfig; \\
    mkdir -p /usr/src/debug; cp -aT /tmp/dbg/usr/src/debug /usr/src/debug; \\
    ln -s "\$(ls -d /usr/src/debug/ghostscript-* | head -1)" /usr/src/ghostscript; \\
    rm -rf /tmp/dbg /tmp/dbg.rpm /tmp/libgs.unstripped

ENV PATH="/opt/gs/bin:\${PATH}"

${labels}

WORKDIR /work
ENTRYPOINT ["gs"]
EOF
    docker build -f "$dockerfile" -t "$image" "$build_context"
    exit 0
fi

if [ "$method" = "deb" ]; then
    ensure_normal_image
    # Write any extra apt sources (e.g. ddebs) into the debug repo list.
    repo_cmd=":"
    if [ -n "$deb_dbg_repo" ]; then
        repo_b64="$(printf '%s\n' "$deb_dbg_repo" | base64 | tr -d '\n')"
        repo_cmd="echo ${repo_b64} | base64 -d > /etc/apt/sources.list.d/debug.list"
    fi
    cat > "$dockerfile" <<EOF
FROM gs-${version}

# Install the distro debug symbols, recombine them into the gs/libgs binaries so
# the executables carry .debug_info, and unpack the matching source.
RUN set -eux; \\
    ${repo_cmd}; \\
    apt-get ${deb_update_opts} update; \\
    apt-get install -y ${deb_install_opts} --no-install-recommends ${deb_dbg_pkgs} \\
        elfutils binutils file curl ca-certificates; \\
    recombine() { \\
        bid="\$(file "\$1" | sed -n 's/.*BuildID\\[sha1\\]=\\([0-9a-f]*\\).*/\\1/p')"; \\
        d="/usr/lib/debug/.build-id/\${bid%\${bid#??}}/\${bid#??}.debug"; \\
        [ -f "\$d" ] || d="/usr/lib/debug\$1.debug"; \\
        [ -f "\$d" ] || d="/usr/lib/debug\$1"; \\
        eu-unstrip "\$1" "\$d" -o "\$2"; \\
    }; \\
    mkdir -p /opt/gs/bin; \\
    recombine "\$(command -v gs)" /opt/gs/bin/gs; chmod +x /opt/gs/bin/gs; \\
    lib="\$(ls /usr/lib/*/libgs.so.*.* /usr/lib/libgs.so.*.* 2>/dev/null | head -1 || true)"; \\
    if [ -n "\$lib" ]; then recombine "\$lib" /tmp/libgs && cp /tmp/libgs "\$lib" && ldconfig; fi; \\
    mkdir -p /usr/src; curl -fSLk "${src_url}" -o /tmp/src.tgz; \\
    tar xzf /tmp/src.tgz -C /tmp; \\
    mv "/tmp/\$(tar tzf /tmp/src.tgz | head -1 | cut -d/ -f1)" /usr/src/ghostscript; \\
    rm -f /tmp/src.tgz /tmp/libgs; \\
    /opt/gs/bin/gs --version

ENV PATH="/opt/gs/bin:\${PATH}"

${labels}

WORKDIR /work
ENTRYPOINT ["gs"]
EOF
    docker build -f "$dockerfile" -t "$image" "$build_context"
    exit 0
fi

if [ "$method" = "rpm-pm" ]; then
    ensure_normal_image
    cat > "$dockerfile" <<EOF
FROM gs-${version}

# Fetch the version-matched ghostscript-debuginfo from the archive, recombine it
# into the gs/libgs binaries so they carry .debug_info, and unpack the matching
# upstream source into /usr/src/ghostscript.
RUN set -eux; \\
    if command -v dnf >/dev/null 2>&1; then dnf install -y elfutils cpio curl file tar gzip >/dev/null; \\
    elif command -v zypper >/dev/null 2>&1; then \\
        zypper mr --enable repo-update repo-update-non-oss >/dev/null 2>&1 || true; \\
        zypper --non-interactive --no-gpg-checks refresh >/dev/null 2>&1 || true; \\
        zypper --non-interactive --no-gpg-checks install --no-recommends elfutils cpio curl file tar gzip >/dev/null; \\
    else yum install -y elfutils cpio curl file tar gzip >/dev/null; fi; \\
    nevr="\$(rpm -q --qf '%{VERSION}-%{RELEASE}.%{ARCH}' ghostscript)"; \\
    mkdir -p /tmp/dbg; cd /tmp/dbg; \\
    got=""; \\
    for base in ${dbg_bases}; do \\
        if curl -fsSL -o /tmp/p.rpm "\$base/ghostscript-debuginfo-\${nevr}.rpm"; then got=1; break; fi; \\
    done; \\
    [ -n "\$got" ] || { echo "could not fetch ghostscript-debuginfo-\${nevr}.rpm" >&2; exit 1; }; \\
    rpm2cpio /tmp/p.rpm | cpio -idm --quiet; rm -f /tmp/p.rpm; \\
    recombine() { \\
        bid="\$(file "\$1" | sed -n 's/.*BuildID\\[sha1\\]=\\([0-9a-f]*\\).*/\\1/p')"; \\
        d="/tmp/dbg/usr/lib/debug/.build-id/\${bid%\${bid#??}}/\${bid#??}.debug"; \\
        [ -f "\$d" ] || d="/tmp/dbg/usr/lib/debug\$1.debug"; \\
        [ -f "\$d" ] || d="\$(find /tmp/dbg/usr/lib/debug -name "\$(basename "\$1")*.debug" | head -1)"; \\
        eu-unstrip "\$1" "\$d" -o "\$2"; \\
    }; \\
    mkdir -p /opt/gs/bin; \\
    recombine "\$(command -v gs)" /opt/gs/bin/gs; chmod +x /opt/gs/bin/gs; \\
    lib="\$(ls /usr/lib64/libgs.so.*.* /usr/lib/libgs.so.*.* 2>/dev/null | head -1 || true)"; \\
    if [ -n "\$lib" ]; then recombine "\$lib" /tmp/libgs && cp /tmp/libgs "\$lib" && ldconfig; fi; \\
    mkdir -p /usr/src; curl -fsSL "${src_url}" -o /tmp/src.tgz; \\
    tar xzf /tmp/src.tgz -C /tmp; \\
    mv "/tmp/\$(tar tzf /tmp/src.tgz | head -1 | cut -d/ -f1)" /usr/src/ghostscript; \\
    rm -rf /tmp/dbg /tmp/libgs /tmp/src.tgz; \\
    /opt/gs/bin/gs --version

ENV PATH="/opt/gs/bin:\${PATH}"

${labels}

WORKDIR /work
ENTRYPOINT ["gs"]
EOF
    docker build -f "$dockerfile" -t "$image" "$build_context"
    exit 0
fi

if [ "$method" = "arch" ]; then
    ensure_normal_image
    # Probe debuginfod for the installed gs build-id; recombine if served.
    arch_bid="$(docker run --rm --entrypoint sh "gs-${version}" -c 'file -L "$(command -v gs)" 2>/dev/null | sed -n "s/.*BuildID\[sha1\]=\([0-9a-f]*\).*/\1/p"')"
    if [ -n "$arch_bid" ] && curl -fsI "https://debuginfod.archlinux.org/buildid/${arch_bid}/debuginfo" >/dev/null 2>&1; then
        echo "debuginfod serves symbols for gs build-id ${arch_bid}; recombining." >&2
        cat > "$dockerfile" <<EOF
FROM gs-${version}

# Arch ships no debug packages, but debuginfod.archlinux.org serves the detached
# symbols by build-id. Fetch them and recombine into gs so the executable carries
# .debug_info, and keep the matching upstream source under /usr/src/ghostscript.
RUN set -eux; \\
    pacman -Sy --noconfirm --needed --overwrite '*' elfutils curl file tar gzip; \\
    bid="\$(file -L "\$(command -v gs)" | sed -n 's/.*BuildID\\[sha1\\]=\\([0-9a-f]*\\).*/\\1/p')"; \\
    mkdir -p /opt/gs/bin; \\
    curl -fsSL "https://debuginfod.archlinux.org/buildid/\${bid}/debuginfo" -o /tmp/gs.debug; \\
    eu-unstrip "\$(command -v gs)" /tmp/gs.debug -o /opt/gs/bin/gs; chmod +x /opt/gs/bin/gs; \\
    mkdir -p /usr/src; curl -fsSL "${src_url}" -o /tmp/src.tgz; \\
    tar xzf /tmp/src.tgz -C /tmp; \\
    mv "/tmp/\$(tar tzf /tmp/src.tgz | head -1 | cut -d/ -f1)" /usr/src/ghostscript; \\
    rm -f /tmp/gs.debug /tmp/src.tgz; \\
    /opt/gs/bin/gs --version

ENV PATH="/opt/gs/bin:\${PATH}"

${labels}

WORKDIR /work
ENTRYPOINT ["gs"]
EOF
        docker build -f "$dockerfile" -t "$image" "$build_context"
        exit 0
    fi
    echo "debuginfod has no symbols for gs build-id ${arch_bid:-unknown}; building gs-debug from source." >&2
    method="source"
fi

# method=source
cat > "$dockerfile" <<EOF
FROM ${base_image}

ARG DEBIAN_FRONTEND=noninteractive
ARG GS_VERSION=${version}

RUN apt-get update && \\
    apt-get install -y --no-install-recommends \\
        autoconf \\
        automake \\
        binutils \\
        build-essential \\
        ca-certificates \\
        curl \\
        file \\
        gdb \\
        libx11-dev \\
        libxext-dev \\
        libxt-dev \\
        ${extra_apt} \\
        && rm -rf /var/lib/apt/lists/*

RUN curl -fSL "${source_url}" -o /tmp/gs.tar.gz && \\
    tar xzf /tmp/gs.tar.gz -C /tmp && \\
    src="${source_dir}" && \\
    if [ "\$src" = "AUTO" ]; then src="/tmp/\$(tar tzf /tmp/gs.tar.gz | head -1 | cut -d/ -f1)"; fi && \\
    mkdir -p /usr/src && mv "\$src" /usr/src/ghostscript && \\
    cd /usr/src/ghostscript && \\
    if [ "${patch_time_h}" = "true" ]; then find . -name time_.h -exec sed -i '/^struct timeval {$/,/^};$/d' {} +; fi && \\
    if [ "${bootstrap}" = "autogen" ]; then cp /usr/share/automake-*/config.guess /usr/share/automake-*/config.sub . 2>/dev/null || true; fi && \\
    export CFLAGS="-g3 -O0 -fno-omit-frame-pointer" && \\
    export CXXFLAGS="-g3 -O0 -fno-omit-frame-pointer" && \\
    if [ "${bootstrap}" = "autogen" ]; then ./autogen.sh --prefix=/opt/gs; else ./configure --prefix=/opt/gs; fi && \\
    make -j${build_jobs} && \\
    make install && \\
    rm -rf /tmp/gs.tar.gz /tmp/ghostpdl-ghostscript-${version} /tmp/ghostscript-${version}

ENV PATH="/opt/gs/bin:\${PATH}"

${labels}

WORKDIR /work
ENTRYPOINT ["gs"]
EOF

docker build -f "$dockerfile" -t "$image" "$build_context"
