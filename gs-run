#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: gs-run <version> [-- <gs args>]"
    echo ""
    echo "Available versions:"
    for d in versions/*/; do
        basename "$d"
    done
    exit 1
fi

VERSION="$1"
shift

if [ "${1:-}" = "--" ]; then
    shift
fi

IMAGE="gs-${VERSION}"

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo "Image $IMAGE not found. Building..."
    docker build -t "$IMAGE" "versions/${VERSION}/"
fi

docker run --rm -i -v "$(pwd):/work" "$IMAGE" "$@"
