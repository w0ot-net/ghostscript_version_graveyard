#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: gs-run [--debug|--combined|--combined-debug] <version> [-- <gs args>]"
    echo ""
    echo "Available versions:"
    for d in versions/*/; do
        basename "$d"
    done
    exit 1
fi

MODE="normal"
case "${1:-}" in
    --debug)
        MODE="debug"
        shift
        ;;
    --combined)
        MODE="combined"
        shift
        ;;
    --combined-debug)
        MODE="combined-debug"
        shift
        ;;
esac

if [ $# -lt 1 ]; then
    echo "Usage: gs-run [--debug|--combined|--combined-debug] <version> [-- <gs args>]" >&2
    exit 1
fi

VERSION="$1"
shift

if [ "${1:-}" = "--" ]; then
    shift
fi

ENTRYPOINT_ARGS=()
case "$MODE" in
    normal)
        IMAGE="gs-${VERSION}"
        ;;
    debug)
        IMAGE="gs-${VERSION}:debug"
        ;;
    combined)
        IMAGE="gs-${VERSION}:combined"
        ;;
    combined-debug)
        IMAGE="gs-${VERSION}:combined"
        ENTRYPOINT_ARGS=(--entrypoint gs-debug)
        ;;
esac

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo "Image $IMAGE not found. Building..."
    if [ "$MODE" = "debug" ]; then
        scripts/build-debug-image "$VERSION" "$IMAGE"
    elif [ "$MODE" = "combined" ] || [ "$MODE" = "combined-debug" ]; then
        scripts/build-combined-image "$VERSION" "$IMAGE"
    else
        docker build -t "$IMAGE" "versions/${VERSION}/"
    fi
fi

docker run --rm -i -v "$(pwd):/work" "${ENTRYPOINT_ARGS[@]}" "$IMAGE" "$@"
