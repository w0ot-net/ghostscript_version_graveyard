#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: gs-run [--debug] <version> [-- <gs args>]"
    echo ""
    echo "Runs the combined image gs-<version>:combined, which contains both the"
    echo "normal 'gs' and the debug 'gs-debug' binaries plus the Ghostscript source."
    echo "  (default)   run gs"
    echo "  --debug     run gs-debug"
    echo ""
    echo "Available versions:"
    for d in versions/*/; do
        basename "$d"
    done
}

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

ENTRYPOINT_ARGS=()
if [ "${1:-}" = "--debug" ]; then
    ENTRYPOINT_ARGS=(--entrypoint gs-debug)
    shift
fi

if [ $# -lt 1 ]; then
    usage >&2
    exit 1
fi

VERSION="$1"
shift

if [ "${1:-}" = "--" ]; then
    shift
fi

IMAGE="gs-${VERSION}:combined"

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
    echo "Image $IMAGE not found. Building..."
    scripts/build-combined-image "$VERSION" "$IMAGE"
fi

docker run --rm -i -v "$(pwd):/work" "${ENTRYPOINT_ARGS[@]}" "$IMAGE" "$@"
